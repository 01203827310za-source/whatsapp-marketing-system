NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/factory_whatsapp
REDIS_URL=redis://localhost:6379
CORS_ORIGIN=http://localhost:5173

JWT_ACCESS_SECRET=replace-with-at-least-32-characters-access
JWT_REFRESH_SECRET=replace-with-at-least-32-characters-refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_DAYS=30

WHATSAPP_VERIFY_TOKEN=replace-me
WHATSAPP_APP_SECRET=replace-me
WHATSAPP_ACCESS_TOKEN=replace-me
WHATSAPP_PHONE_NUMBER_ID=replace-me

CLOUDINARY_CLOUD_NAME=replace-me
CLOUDINARY_API_KEY=replace-me
CLOUDINARY_API_SECRET=replace-me

BROADCAST_BATCH_SIZE=50
BROADCAST_DELAY_MS=1000
SEED_OWNER_EMAIL=owner@example.com
SEED_OWNER_PASSWORD=ChangeMe123!
